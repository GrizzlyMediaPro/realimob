generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Listing {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Informații de bază
  title            String
  description      String
  transactionType  String
  propertyType     String
  commercialSubtype String?
  price            Float
  currency         String
  location         String
  address          String?
  sector           String?

  // Coordonate hartă
  latitude  Float?
  longitude Float?

  // Status moderare (pending / approved / denied)
  status    String  @default("pending")

  // Agent atribuit
  agentId   String? @db.ObjectId
  agent     Agent?  @relation(fields: [agentId], references: [id])

  // Alte detalii salvate flexibil
  details Json?
  images  Json?
}

model Agent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  email     String?
  phone     String?
  avatar    String?

  // Sectoare în care operează agentul (ex: ["Sector 1", "Sector 2"])
  sectors   String[]

  // Rating agent (1-5, cu zecimale)
  rating    Float    @default(3.0)

  // Anunțuri atribuite
  listings  Listing[]
}