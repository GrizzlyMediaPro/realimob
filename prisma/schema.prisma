generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Listing {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Informații de bază
  title            String
  description      String
  transactionType  String
  propertyType     String
  commercialSubtype String?
  price            Float
  currency         String
  location         String
  address          String?
  sector           String?

  // Coordonate hartă
  latitude  Float?
  longitude Float?

  // Status moderare: pending | approved | denied | sold (sold = verificat de admin după contract)
  status    String  @default("pending")

  /// Contract vânzare-cumparare (sau echivalent) încărcat de agent; verificare admin
  saleContractUrl     String?
  saleContractFileName String?
  saleSubmittedAt     DateTime?
  saleVerifiedAt      DateTime?
  saleRejectedAt      DateTime?
  saleRejectionNote   String?

  /// Clerk user id — cine a trimis anunțul (cont utilizator)
  submittedByUserId String?

  // Agent atribuit
  agentId   String? @db.ObjectId
  agent     Agent?  @relation(fields: [agentId], references: [id])

  // Cereri de vizionare (programare prin Google Calendar)
  viewingRequests ViewingBookingRequest[]

  viewingQuestionnaires ViewingQuestionnaire[]
  listingOffers         ListingOffer[]

  // Alte detalii salvate flexibil
  details Json?
  images  Json?
}

model Agent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  email     String?
  phone     String?
  avatar    String?

  // Sectoare în care operează agentul (ex: ["Sector 1", "Sector 2"])
  sectors   String[]

  // Rating agent (1-5, cu zecimale)
  rating    Float    @default(3.0)

  // Google Calendar (OAuth) – refresh token în DB; evenimente în calendarul „primary” al contului conectat
  googleRefreshToken          String?
  googleCalendarEmail         String?
  googleCalendarConnectedAt   DateTime?

  // Anunțuri atribuite
  listings                Listing[]
  viewingRequests         ViewingBookingRequest[]
  appNotifications        AppNotification[]
  viewingQuestionnaires   ViewingQuestionnaire[]
}

/// Cerere de vizionare: clientul alege interval din disponibilitate; agentul aprobă → eveniment în Google Calendar.
model ViewingBookingRequest {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listingId String  @db.ObjectId
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  agentId   String  @db.ObjectId
  agent     Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  startAt DateTime
  endAt   DateTime

  clientName  String
  clientEmail String
  clientPhone String?

  message String?

  /// pending | approved | rejected
  status String @default("pending")

  googleEventId String?

  questionnaire ViewingQuestionnaire?
  listingOffers ListingOffer[]
}

/// Deschis automat după `endAt` pentru vizionări aprobate — răspunsuri agent + client.
model ViewingQuestionnaire {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  viewingRequestId String               @unique @db.ObjectId
  viewingRequest   ViewingBookingRequest @relation(fields: [viewingRequestId], references: [id], onDelete: Cascade)

  listingId String  @db.ObjectId
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  agentId String @db.ObjectId
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  /// Email client normalizat (lowercase), pentru potrivire cu contul Clerk
  clientEmail String

  agentSubmittedAt   DateTime?
  clientSubmittedAt DateTime?

  /// Răspunsuri structurate (JSON): attended, interestLevel, notes, wantsOffer, offerAmount, etc.
  agentAnswers   Json?
  clientAnswers  Json?
}

/// Oferte legate de anunț; cele de la client rămân pending până le confirmă agentul.
model ListingOffer {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listingId String  @db.ObjectId
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  viewingRequestId String? @db.ObjectId
  viewingRequest   ViewingBookingRequest? @relation(fields: [viewingRequestId], references: [id], onDelete: SetNull)

  /// client | agent
  proposedBy String

  amount   Float
  currency String @default("RON")

  note String?

  /// pending | confirmed | declined
  status String @default("pending")
}

/// Notificări în aplicație (agent după agentId, client după email).
model AppNotification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  readAt    DateTime?

  type  String
  title String
  body  String
  href  String?

  agentId String? @db.ObjectId
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  clientEmail String?
}

/// Preferințe globale: cine primește emailuri pe tip de conținut (agenți / clienți / admini).
model EmailTopicPreference {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  topicId        String   @unique
  label          String
  description    String?
  sendToAgents   Boolean  @default(true)
  sendToClients  Boolean  @default(true)
  sendToAdmins   Boolean  @default(false)
  sortOrder      Int      @default(0)
  updatedAt      DateTime @updatedAt
}

/// Șabloane HTML create din panou (pentru campanii sau mesaje reutilizabile).
model EmailTemplate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  subject   String
  bodyHtml  String
  active    Boolean  @default(true)
}

/// Setări globale platformă (un singur document cu key unică).
model PlatformSettings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  siteName  String   @default("realimob")
  supportEmail String?
  supportPhone String?
  defaultCurrency String @default("RON")
  registrationsEnabled Boolean @default(true)
  newListingsAutoApprove Boolean @default(false)

  /// Centru oraș (Punctul 0) pentru scoruri distanță — opțional; altfel env / default București
  cityCenterLatitude  Float?
  cityCenterLongitude Float?

  updatedAt DateTime @updatedAt
}